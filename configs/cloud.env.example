# Cloud bind address
HANK_REMOTE_CLOUD_ADDR=:8080

# PostgreSQL connection URL
HANK_REMOTE_CLOUD_DATABASE_URL=postgres://hankremote:hankremote@127.0.0.1:5432/hankremote?sslmode=disable

# Local PostgreSQL credentials for development
POSTGRES_DB=hankremote
POSTGRES_USER=hankremote
POSTGRES_PASSWORD=hankremote

# App session lifetime in seconds
HANK_REMOTE_SESSION_TTL_SECONDS=604800

# Cloud relay timeout for routed app requests
HANK_REMOTE_REQUEST_TIMEOUT_SECONDS=30
