# Cloud bind address inside the container.
HANK_REMOTE_CLOUD_ADDR=:8080

# Host bind address and published port for the cloud container.
HANK_REMOTE_CLOUD_HOST_BIND=0.0.0.0
HANK_REMOTE_CLOUD_HOST_PORT=18080

# PostgreSQL connection URL inside docker-compose.
HANK_REMOTE_CLOUD_DATABASE_URL=postgres://hankremote:hankremote@postgres:5432/hankremote?sslmode=disable

# PostgreSQL service credentials.
POSTGRES_DB=hankremote
POSTGRES_USER=hankremote
POSTGRES_PASSWORD=hankremote

# App session lifetime in seconds.
HANK_REMOTE_SESSION_TTL_SECONDS=604800

# Timeout for routed app requests.
HANK_REMOTE_REQUEST_TIMEOUT_SECONDS=30
