# The cloud agent websocket endpoint.
HANK_REMOTE_AGENT_CLOUD_URL=ws://127.0.0.1:8080/ws/agent

# Agent identity and issued agent token.
HANK_REMOTE_AGENT_ID=home-main
HANK_REMOTE_AGENT_TOKEN=replace-with-issued-token

# Friendly metadata shown to the cloud service.
HANK_REMOTE_AGENT_HOME_NAME=Aaron Home

# Optional Home Assistant connectivity.
HANK_REMOTE_HA_BASE_URL=http://127.0.0.1:8123
HANK_REMOTE_HA_TOKEN=replace-with-home-assistant-token
HANK_REMOTE_HA_TIMEOUT_SECONDS=10

# Optional local filesystem root for file relay operations.
HANK_REMOTE_AGENT_FILES_ROOT=/srv/hank/files

# Optional direct SMB backend. If set, SMB is used instead of the local files root.
HANK_REMOTE_SMB_HOST=
HANK_REMOTE_SMB_SHARE=
HANK_REMOTE_SMB_USERNAME=
HANK_REMOTE_SMB_PASSWORD=
HANK_REMOTE_SMB_DOMAIN=

# Optional local notes root for note relay operations.
HANK_REMOTE_AGENT_NOTES_ROOT=/srv/hank/notes
