{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["text", "destination_path", "files"],
  "properties": {
    "text": { "type": "string" },
    "source_id": { "type": "string" },
    "destination_path": { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size"],
        "properties": {
          "path": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
