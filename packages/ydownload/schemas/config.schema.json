{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source_id": { "type": "string" },
    "destination_path": { "type": "string", "default": "YouTube" },
    "format": { "type": "string", "default": "best" },
    "output_template": { "type": "string", "default": "%(title).200B [%(id)s].%(ext)s" },
    "write_subtitles": { "type": "boolean", "default": false },
    "write_auto_subtitles": { "type": "boolean", "default": false },
    "subtitle_languages": { "type": "string", "default": "en.*,all,-live_chat" },
    "subtitle_format": { "type": "string", "default": "srt/best" },
    "write_thumbnail": { "type": "boolean", "default": false },
    "write_info_json": { "type": "boolean", "default": false },
    "download_playlist": { "type": "boolean", "default": false },
    "restrict_filenames": { "type": "boolean", "default": true },
    "no_overwrite": { "type": "boolean", "default": true },
    "rate_limit": { "type": "string" },
    "proxy_url": { "type": "string", "format": "uri" },
    "cookies_file_path": { "type": "string" },
    "yt_dlp_path": { "type": "string", "default": "yt-dlp" },
    "timeout_seconds": { "type": "integer", "minimum": 1, "default": 900 },
    "files_root": { "type": "string" }
  }
}
