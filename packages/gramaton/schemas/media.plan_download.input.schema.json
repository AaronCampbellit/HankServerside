{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["selection"],
  "properties": {
    "selection": { "type": "object", "additionalProperties": true },
    "filter": {
      "type": "object",
      "properties": {
        "season": { "type": "integer", "minimum": 1 },
        "episode": { "type": "integer", "minimum": 1 },
        "all": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
