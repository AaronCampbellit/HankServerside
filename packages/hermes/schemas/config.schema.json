{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["api_base_url", "model", "timeout_seconds"],
  "additionalProperties": false,
  "properties": {
    "api_base_url": {
      "type": "string",
      "format": "uri"
    },
    "model": {
      "type": "string",
      "default": "hermes-agent"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300,
      "default": 120
    },
    "api_key": {
      "type": "string",
      "writeOnly": true
    }
  }
}
