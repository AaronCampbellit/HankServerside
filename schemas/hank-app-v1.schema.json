{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hank.local/schemas/hank-app-v1.schema.json",
  "title": "Hank App Manifest v1",
  "description": "Manifest for app.json at the root of a Hank app folder or .hankapp archive. The package root must contain this app.json, the runtime.command file, and every schema file referenced by config.schema, commands[].input_schema, and commands[].output_schema.",
  "$comment": "Settings > Apps can accept either a prebuilt .hankapp archive or a top-level app folder. Folder upload strips the selected top-level folder name before packaging, so my-app/app.json becomes app.json at the archive root. This schema validates app.json only; archive containment, file existence, executable behavior, schema JSON contents, and cross-field permission/secret relationships are enforced by the HankServerside runtime validator.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "name", "version", "runtime", "commands"],
  "properties": {
    "schema_version": {
      "const": "hank.app.v1"
    },
    "id": {
      "$ref": "#/$defs/identifier",
      "description": "Stable app identifier. It also becomes the installed app directory name."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "publisher": {
      "type": "string",
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "command"],
      "properties": {
        "type": {
          "const": "stdio"
        },
        "command": {
          "$ref": "#/$defs/package_path",
          "description": "Clean relative path to the stdio executable inside the app package, for example bin/my-app. Runtime args are not supported in hank.app.v1."
        }
      }
    },
    "assistant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "slash_commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "command_id"],
            "properties": {
              "command": {
                "type": "string",
                "pattern": "^/[A-Za-z][A-Za-z0-9_-]*$"
              },
              "command_id": {
                "$ref": "#/$defs/identifier"
              },
              "description": {
                "type": "string",
                "maxLength": 160
              }
            }
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "mode"],
        "properties": {
          "id": {
            "$ref": "#/$defs/identifier"
          },
          "mode": {
            "const": "request_response"
          },
          "input_schema": {
            "$ref": "#/$defs/package_path"
          },
          "output_schema": {
            "$ref": "#/$defs/package_path"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 300
          },
          "admin_only": {
            "type": "boolean"
          }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema": {
          "$ref": "#/$defs/package_path",
          "description": "Clean relative path to a JSON object schema file inside the package."
        },
        "secret_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "settings_schema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fields": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/settings_field"
              }
            }
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": {
              "kind": {
                "const": "configured_base_url"
              },
              "field": {
                "$ref": "#/$defs/identifier"
              }
            }
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "field"],
            "properties": {
              "kind": {
                "const": "configured_source"
              },
              "field": {
                "$ref": "#/$defs/identifier"
              },
              "label": {
                "type": "string"
              }
            }
          }
        },
        "events": {
          "type": "array",
          "maxItems": 0
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "package_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$))(?!.*(^|/)\\.(/|$))(?!.*//)(?!.*\\\\)[^\\u0000]*$",
      "description": "Clean relative package path. Do not use absolute paths, dot segments, parent traversal, double slashes, backslashes, or NUL bytes."
    },
    "settings_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "type"],
      "properties": {
        "key": {
          "$ref": "#/$defs/identifier"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "enum": ["boolean", "number", "password", "path", "select", "text", "url"]
        },
        "required": {
          "type": "boolean"
        },
        "secret": {
          "type": "boolean"
        },
        "secret_key": {
          "$ref": "#/$defs/identifier"
        },
        "source": {
          "enum": ["file_sources"]
        },
        "placeholder": {
          "type": "string"
        },
        "help": {
          "type": "string"
        },
        "default": {
          "type": ["string", "number", "boolean"]
        },
        "order": {
          "type": "integer"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value"],
            "properties": {
              "value": {
                "type": ["string", "number", "boolean"]
              },
              "label": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
