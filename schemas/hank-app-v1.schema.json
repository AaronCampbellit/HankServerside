{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hank.local/schemas/hank-app-v1.schema.json",
  "title": "Hank App Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "name", "version", "runtime", "commands"],
  "properties": {
    "schema_version": {
      "const": "hank.app.v1"
    },
    "id": {
      "$ref": "#/$defs/identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "publisher": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "command"],
      "properties": {
        "type": {
          "const": "stdio"
        },
        "command": {
          "$ref": "#/$defs/package_path"
        }
      }
    },
    "assistant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "slash_commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "command_id"],
            "properties": {
              "command": {
                "type": "string",
                "pattern": "^/[A-Za-z][A-Za-z0-9_-]*$"
              },
              "command_id": {
                "$ref": "#/$defs/identifier"
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "mode"],
        "properties": {
          "id": {
            "$ref": "#/$defs/identifier"
          },
          "mode": {
            "const": "request_response"
          },
          "input_schema": {
            "$ref": "#/$defs/package_path"
          },
          "output_schema": {
            "$ref": "#/$defs/package_path"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "admin_only": {
            "type": "boolean"
          }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema": {
          "$ref": "#/$defs/package_path"
        },
        "secret_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "settings_schema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fields": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/settings_field"
              }
            }
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": {
              "kind": {
                "const": "configured_base_url"
              },
              "field": {
                "$ref": "#/$defs/identifier"
              }
            }
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "field"],
            "properties": {
              "kind": {
                "const": "configured_source"
              },
              "field": {
                "$ref": "#/$defs/identifier"
              },
              "label": {
                "type": "string"
              }
            }
          }
        },
        "events": {
          "type": "array",
          "maxItems": 0
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "package_path": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$))[^\\u0000]*$"
    },
    "settings_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "type"],
      "properties": {
        "key": {
          "$ref": "#/$defs/identifier"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "enum": ["boolean", "number", "password", "path", "select", "text", "url"]
        },
        "required": {
          "type": "boolean"
        },
        "secret": {
          "type": "boolean"
        },
        "secret_key": {
          "$ref": "#/$defs/identifier"
        },
        "source": {
          "enum": ["file_sources"]
        },
        "placeholder": {
          "type": "string"
        },
        "help": {
          "type": "string"
        },
        "default": {
          "type": ["string", "number", "boolean"]
        },
        "order": {
          "type": "integer"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value"],
            "properties": {
              "value": {
                "type": ["string", "number", "boolean"]
              },
              "label": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
